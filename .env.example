# -----------------------------------------------------------------------------
# AI Interviewer Server - Environment Configuration Template
# Copy this file to '.env' and fill in your values for local run or production.
# -----------------------------------------------------------------------------

# Port number for the Express server to listen on
PORT=3000

# Primary Groq API key for AI text response and proctoring vision detection
GROQ_API_KEY=your_primary_groq_api_key_here

# Secondary fallback Groq API key (used automatically if the primary key fails or reaches quota limit)
SECONDARY_GROQ_API_KEY=your_fallback_groq_api_key_here

# Default Groq LLM model to try first for text completions
GROQ_MODEL=llama-3.3-70b-versatile

# Note: ElevenLabs is no longer used. TTS voice is generated locally via Coqui TTS.
